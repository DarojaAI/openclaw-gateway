{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DarojaAI/openclaw-gateway/schemas/agent-config.schema.json",
  "title": "OpenClaw agent-config.yaml",
  "description": "Per-agent identity, capability, and channel-binding declaration. Consumed by the openclaw-gateway deploy action to generate agents.lock.toml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["handle", "contract_version"],
  "properties": {
    "handle": {
      "type": "string",
      "description": "Discord @-mention used in chat. Must start with @.",
      "pattern": "^@[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
    },
    "contract_version": {
      "type": "string",
      "description": "Inter-agent protocol version this agent obeys.",
      "enum": ["v1"]
    },
    "capabilities": {
      "type": "array",
      "description": "Declared capabilities this agent serves.",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "allowed_channels": {
      "type": "array",
      "description": "Discord channels where this agent may receive direct @-mentions.",
      "items": { "type": "string", "pattern": "^#?[a-z0-9][a-z0-9_-]*$" },
      "uniqueItems": true
    },
    "role": {
      "type": "string",
      "description": "Agent role.",
      "enum": ["executor", "advisor"]
    },
    "skills": {
      "type": "array",
      "description": "Skill names this agent declares it can serve.",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "heartbeat": {
      "type": "object",
      "description": "Heartbeat configuration. Phase 6 health/quarantine.",
      "additionalProperties": false,
      "required": ["enabled", "interval_hours"],
      "properties": {
        "enabled": { "type": "boolean" },
        "interval_hours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 168
        }
      }
    },
    "canary": {
      "type": "boolean",
      "description": "If true, the gateway routes ~10% of traffic here."
    }
  }
}
