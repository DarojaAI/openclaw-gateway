{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenCLAW Config Schema",
  "description": "Schema for OpenCLAW configuration files",
  "type": "object",
  "required": ["agents", "channels"],
  "properties": {
    "agents": {
      "type": "object",
      "required": ["defaults"],
      "properties": {
        "defaults": {
          "type": "object",
          "required": ["model", "maxConcurrent"],
          "properties": {
            "model": {
              "type": "string",
              "pattern": "^openrouter/[^/]+/[^/]+$",
              "description": "OpenRouter model in format: openrouter/provider/model"
            },
            "models": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "alias": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_-]*$"
                  }
                }
              }
            },
            "maxConcurrent": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 4
            },
            "subagents": {
              "type": "object",
              "properties": {
                "maxConcurrent": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                }
              }
            },
            "compaction": {
              "type": "object",
              "properties": {
                "reserveTokensFloor": {
                  "type": "integer",
                  "minimum": 10000,
                  "default": 20000
                },
                "keepRecentTokens": {
                  "type": "integer",
                  "minimum": 1000
                },
                "maxHistoryShare": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            },
            "thinkingDefault": {
              "type": "string",
              "enum": ["minimal", "low", "medium", "high"],
              "default": "minimal"
            }
          }
        }
      }
    },
    "channels": {
      "type": "object",
      "required": ["discord"],
      "properties": {
        "discord": {
          "type": "object",
          "required": ["token"],
          "properties": {
            "token": {
              "type": "string",
              "pattern": "^\\$\\{DISCORD_BOT_TOKEN\\}$",
              "description": "Must reference environment secret"
            },
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "allowFrom": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "groupPolicy": {
              "type": "string",
              "enum": ["allowlist", "blocklist"],
              "default": "allowlist"
            },
            "threadBindings": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "idleHours": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 168,
                  "default": 24
                },
                "maxAgeHours": {
                  "type": "integer",
                  "minimum": 0
                },
                "spawnAcpSessions": {
                  "type": "boolean"
                }
              }
            },
            "streaming": {
              "type": "object",
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": ["off", "streaming", "partial"]
                }
              }
            }
          }
        }
      }
    },
    "browser": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "headless": {
          "type": "boolean"
        },
        "noSandbox": {
          "type": "boolean"
        }
      }
    },
    "commands": {
      "type": "object",
      "properties": {
        "native": {
          "type": "string",
          "enum": ["auto", "native", "disabled"]
        },
        "nativeSkills": {
          "type": "string",
          "enum": ["auto", "native", "disabled"]
        }
      }
    }
  }
}
